# Structurizr Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file with real secrets to version control!

# =============================================================================
# API Keys (Replace with your actual keys)
# =============================================================================

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API Key
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cerebras API Key (if used)
# Get from: https://cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here

# =============================================================================
# Structurizr Configuration (Optional - can also be set in compose.yaml)
# =============================================================================

# Allow editing workspace via UI (true/false)
# STRUCTURIZR_EDITABLE=true

# Auto-save interval in milliseconds (0 = disabled)
# STRUCTURIZR_AUTOSAVEINTERVAL=2000

# Auto-refresh interval in milliseconds (0 = disabled)
# STRUCTURIZR_AUTOREFRESHINTERVAL=2000

# =============================================================================
# Other Service Configurations (Add as needed)
# =============================================================================

# Notion API Token (if documenting Notion integration)
# NOTION_API_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slack Webhook URL (if documenting Slack integration)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxxxxxxxxxx

# Google Calendar API credentials (if documenting)
# GOOGLE_CALENDAR_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Database Credentials (if documenting database systems)
# =============================================================================

# POSTGRES_USER=myuser
# POSTGRES_PASSWORD=mypassword
# POSTGRES_DB=mydatabase

# =============================================================================
# Notes
# =============================================================================

# 1. Copy this file: cp .env.example .env
# 2. Fill in real values in .env
# 3. Keep .env out of git (it's in .gitignore)
# 4. Rotate keys regularly
# 5. Use secret management tools in production
